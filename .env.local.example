# コピーして .env.local にリネームし、実際のキーを入れてください
ANTHROPIC_API_KEY=sk-ant-...

# iPhone / iOS対応 (Groq Whisper) — https://console.groq.com で無料取得
GROQ_API_KEY=gsk_...

# 話者自動分離 (Deepgram) — https://console.deepgram.com で無料取得 (12,000分/月)
DEEPGRAM_API_KEY=

# リアルタイム同期 (Pusher) — https://pusher.com で無料取得 (200k msg/日)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=   # PUSHER_KEY と同じ値（ブラウザ用）
NEXT_PUBLIC_PUSHER_CLUSTER=  # PUSHER_CLUSTER と同じ値（ブラウザ用）
